{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/admin.html",
      "has": [
        {
          "type": "host",
          "value": "admin.bustime.site"
        }
      ]
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
